# Eval workspaces (local testing artifacts)
*-workspace/

# OS files
.DS_Store

# Claude local files
.claude/
# Allow the maintainer skill (internal tooling, committed)
!.claude/
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/etyb-oss-maintainer/
!.claude/skills/etyb-oss-maintainer/**
!.claude/commands/
.claude/commands/*
!.claude/commands/etyb-oss-maintainer.md

# Internal documents (not for public distribution)
MARKETPLACE.md
docs/plan-*.md
.internal/

# ETYB runtime artifacts (created during usage)
.etyb/

# Python bytecode from Codex hook execution
__pycache__/
*.pyc
